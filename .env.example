# Yahoo options server (local dev)
YAHOO_API_PORT=8788
YAHOO_CACHE_TTL_MS=120000
YAHOO_MIN_GAP_MS=1500

# Robinhood live fallback (uses your existing Robinhood web session — no new signup)
# Run: npm run robinhood-token-help
ROBINHOOD_BROKERAGE_TOKEN=
ROBINHOOD_MIN_GAP_MS=200
ROBINHOOD_MARKETDATA_BATCH_SIZE=40
# Set true to use Robinhood live data first (Yahoo as fallback)
ROBINHOOD_PRIMARY=true
# Set true ONLY when you want to allow live option orders to your Robinhood account
ROBINHOOD_TRADING_ENABLED=false

# Frontend (production deploy)
# VITE_YAHOO_API_BASE=https://your-options-api.example.com
