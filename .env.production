# Production environment variables for GitHub Pages deployment
# This file is used when running `npm run build`

# Yahoo Options API Backend (Render)
VITE_YAHOO_API_BASE=https://optionanalysis.onrender.com

# Keep other production settings if needed
VITE_DATA_SOURCE=api
VITE_OPTIONS_AUTO_REFRESH_MS=180000
VITE_OPTIONS_LOOKBACK_DAYS=7
